# Supabase (client-side) — the anon/publishable key is safe to expose in the browser
# ONLY when Row-Level Security is enabled on your tables.
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_REF"

# ---------------------------------------------------------------------------
# The following are configured as Supabase Edge Function SECRETS, not here.
# Set them with:  supabase secrets set NEWS_API_KEY=... GA4_PROPERTY_ID=... etc.
# Never place these in a VITE_-prefixed variable — that would ship them to the browser.
#
#   NEWS_API_KEY          # https://newsapi.org  (used by fetch-news)
#   GA4_PROPERTY_ID       # Google Analytics 4 property id (used by fetch-analytics)
#   GOOGLE_CLIENT_EMAIL   # GA service-account email
#   GOOGLE_PRIVATE_KEY    # GA service-account private key
#   ALLOWED_ORIGINS       # comma-separated allow-list for CORS, e.g. https://app.example.com
# ---------------------------------------------------------------------------
